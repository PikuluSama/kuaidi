<navigation-bar title="{{companyName}}查询" back="{{true}}" background-color="#FFFFFF" color="#111111"></navigation-bar>

<scroll-view scroll-y style="height: 100vh; background-color: #F5F5F5;">
  <view class="card">
    <view class="company-name">{{companyName}}</view>
    <view class="company-intro">{{companyIntro}}</view>
  </view>

  <view class="card query-card">
    <input class="input" placeholder="请输入{{companyName}}单号" value="{{num}}" bindinput="onNumInput" maxlength="30" />
    <button class="btn-primary" bindtap="onQuery">查询</button>
  </view>

  <view class="card faq-card">
    <view class="faq-title">常见问题</view>
    <view class="faq-item">
      <view class="faq-q">如何查询{{companyName}}？</view>
      <view class="faq-a">在上方输入框中输入您的{{companyName}}快递单号，点击查询即可查看物流轨迹。系统会自动识别快递公司。</view>
    </view>
    <view class="faq-item">
      <view class="faq-q">{{companyName}}单号格式是什么？</view>
      <view class="faq-a">{{numFormat}}</view>
    </view>
    <view class="faq-item">
      <view class="faq-q">{{companyName}}客服电话是多少？</view>
      <view class="faq-a">{{phone}}</view>
    </view>
  </view>

  <view class="card links-card">
    <view class="links-title">其他快递查询</view>
    <view class="links-grid">
      <navigator url="/pages/company/shunfeng" class="link-item" hover-class="link-hover">顺丰速运</navigator>
      <navigator url="/pages/company/zhongtong" class="link-item" hover-class="link-hover">中通快递</navigator>
      <navigator url="/pages/company/yuantong" class="link-item" hover-class="link-hover">圆通速递</navigator>
      <navigator url="/pages/company/yunda" class="link-item" hover-class="link-hover">韵达快递</navigator>
      <navigator url="/pages/company/jitu" class="link-item" hover-class="link-hover">极兔速递</navigator>
      <navigator url="/pages/company/jingdong" class="link-item" hover-class="link-hover">京东物流</navigator>
      <navigator url="/pages/company/ems" class="link-item" hover-class="link-hover">EMS</navigator>
    </view>
  </view>
</scroll-view>
