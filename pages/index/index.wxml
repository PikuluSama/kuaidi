<!-- pages/index/index.wxml -->
<navigation-bar title="快递查询" back="{{false}}" background-color="#FFFFFF" color="#111111"></navigation-bar>

<scroll-view scroll-y style="height: 100vh; background-color: #F5F7F5;">

  <!-- 剪贴板提示 -->
  <view class="clipboard-tip" wx:if="{{clipboardTip}}">
    <view class="clipboard-main" bindtap="onTapClipboard">
      <text class="clipboard-label">检测到剪贴板中的运单号</text>
      <text class="clipboard-value">{{clipboardTip}}</text>
    </view>
    <text class="clipboard-close" catchtap="onDismissClipboard">关闭</text>
  </view>

  <!-- 查询区域 -->
  <view class="card query-card">
    <view class="query-eyebrow">快递物流查询</view>
    <view class="query-title">输入单号，快速查看最新物流状态</view>
    <view class="query-subtitle">支持自动识别快递公司，常用信息会在本机保留，便于继续查询。</view>

    <input
      class="input"
      placeholder="请输入快递单号"
      placeholder-class="input-placeholder"
      value="{{trackingNum}}"
      bindinput="onNumInput"
      maxlength="30"
      disabled="{{loading}}"
    />

    <view class="phone-panel" wx:if="{{showPhoneInput}}">
      <view class="phone-copy">查询此快递需要收件手机号后4位验证。</view>
      <input
        class="input phone-input"
        placeholder="请输入收件手机号后4位"
        placeholder-class="input-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="4"
        type="number"
        disabled="{{loading}}"
      />
    </view>

    <button
      class="btn-primary query-btn {{loading ? 'disabled' : ''}}"
      bindtap="onQuery"
      disabled="{{loading}}"
    >
      {{loading ? '查询中...' : '查询'}}
    </button>

    <view class="remaining-tip text-secondary" wx:if="{{remainingTip}}">
      <text>{{remainingTip}}</text>
    </view>
  </view>

  <!-- 查询历史 -->
  <view class="history-section" wx:if="{{history.length > 0}}">
    <view class="history-header">
      <text class="history-title">查询历史</text>
      <text class="history-clear" bindtap="onClearHistory">清空</text>
    </view>

    <view class="history-list">
      <view
        class="history-item"
        wx:for="{{history}}"
        wx:key="num"
        bindtap="onHistoryTap"
        data-item="{{item}}"
      >
        <view class="history-main">
          <view class="history-head">
            <view class="history-num">{{item.num}}</view>
            <text class="history-state">{{item.stateName}}</text>
          </view>
          <view class="history-meta">
            <text class="history-com">{{item.comName}}</text>
            <text class="history-time">{{item.queryTimeText || ''}}</text>
          </view>
          <view class="history-trace text-secondary">{{item.lastTrace}}</view>
        </view>
        <view class="history-actions">
          <view class="history-delete" catchtap="onHistoryDelete" data-num="{{item.num}}">移除</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{history.length === 0 && !loading}}">
    <text class="empty-title">还没有查询记录</text>
    <text class="text-secondary">查询过的单号会保存在本机，方便你快速继续查看。</text>
  </view>

</scroll-view>
