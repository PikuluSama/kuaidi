/* pages/index/index.wxss */

.clipboard-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 32rpx 0;
  padding: 22rpx 24rpx;
  background-color: var(--color-brand-soft);
  border-radius: var(--radius-md);
  color: var(--color-primary);
}

.clipboard-main {
  flex: 1;
  min-width: 0;
}

.clipboard-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 6rpx;
}

.clipboard-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  word-break: break-all;
}

.clipboard-close {
  color: var(--color-brand);
  margin-left: 24rpx;
  font-size: 24rpx;
}

.query-card {
  margin-top: 24rpx;
}

.query-eyebrow {
  font-size: 22rpx;
  color: var(--color-brand);
  margin-bottom: 12rpx;
}

.query-title {
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 600;
  color: var(--color-primary);
}

.query-subtitle {
  margin-top: 12rpx;
  margin-bottom: 28rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.query-card .input {
  width: 100%;
  box-sizing: border-box;
}

.form-helper-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.helper-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.company-picker {
  max-width: 60%;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  font-size: 26rpx;
  color: var(--color-primary);
}

.picker-arrow {
  font-size: 22rpx;
  color: var(--color-brand);
}

.phone-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  background-color: var(--color-bg-soft);
  border-radius: var(--radius-md);
}

.phone-copy {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.phone-input {
  margin-top: 0;
}

.query-btn {
  width: 100% !important;
  margin-top: 28rpx;
}

.query-btn.disabled {
  background-color: var(--color-border);
  color: var(--color-text-tertiary);
}

.remaining-tip {
  margin-top: 16rpx;
}

.history-section {
  margin: 24rpx 32rpx;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.history-clear {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.history-list {
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.history-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.history-item:last-child {
  border-bottom: none;
}

.history-main {
  flex: 1;
  min-width: 0;
}

.history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.history-num {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 10rpx;
  word-break: break-all;
}

.history-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.history-com {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.history-state {
  font-size: 22rpx;
  color: var(--color-brand);
  background-color: var(--color-brand-soft);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.history-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.history-trace {
  line-height: 1.6;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.history-actions {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding-top: 4rpx;
}

.history-delete {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 6rpx 12rpx;
}

.empty-state {
  text-align: center;
  padding: 104rpx 48rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}
