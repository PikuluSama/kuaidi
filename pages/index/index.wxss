/* pages/index/index.wxss */

.clipboard-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 32rpx 0;
  padding: 22rpx 24rpx;
  background-color: var(--color-brand-soft);
  border-radius: var(--radius-md);
  color: var(--color-primary);
}

.clipboard-main {
  flex: 1;
  min-width: 0;
}

.clipboard-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 6rpx;
}

.clipboard-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  word-break: break-all;
}

.clipboard-hint {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--color-brand);
  margin-left: 8rpx;
}

.clipboard-main:active {
  opacity: 0.7;
}

.clipboard-close {
  color: var(--color-brand);
  margin-left: 24rpx;
  font-size: 24rpx;
}

.query-card {
  margin-top: 24rpx;
}

.query-eyebrow {
  font-size: 22rpx;
  color: var(--color-brand);
  margin-bottom: 12rpx;
}

.query-title {
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 600;
  color: var(--color-primary);
}

.query-subtitle {
  margin-top: 12rpx;
  margin-bottom: 28rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.query-card .input {
  width: 100%;
  box-sizing: border-box;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.input-row .input-field {
  flex: 1;
  min-width: 0;
}

.input-paste {
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--color-brand);
  padding: 0 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  white-space: nowrap;
}

.input-paste:active {
  opacity: 0.7;
}

.phone-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  background-color: var(--color-bg-soft);
  border-radius: var(--radius-md);
}

.phone-copy {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.phone-input {
  margin-top: 0;
}

.query-btn {
  width: 100% !important;
  margin-top: 28rpx;
}

.query-btn.disabled {
  background-color: var(--color-border);
  color: var(--color-text-tertiary);
}

.remaining-tip {
  margin-top: 16rpx;
}

.history-list .tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
}

.history-section {
  margin: 28rpx 32rpx 40rpx;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.history-clear {
  font-size: 24rpx;
  color: var(--color-brand);
}

.history-clear:active {
  opacity: 0.65;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 24rpx;
  background-color: var(--color-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
}

.history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-num-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
}

.history-num {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  line-height: 1.24;
  word-break: break-all;
}

.history-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  line-height: 1.3;
}

.history-com {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.history-com::after {
  content: '·';
  margin: 0 8rpx;
}

.history-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.history-trace {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.history-delete {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  padding: 10rpx 18rpx;
}

.history-delete:active {
  opacity: 0.6;
}

.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 16rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--color-text-secondary);
}
