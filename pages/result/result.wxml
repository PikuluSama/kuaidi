<!-- pages/result/result.wxml -->
<navigation-bar title="物流详情" back="{{true}}" background-color="#FFFFFF" color="#111111"></navigation-bar>

<scroll-view scroll-y style="height: calc(100vh - 44px - env(safe-area-inset-top)); background-color: #F5F7F5;">

  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="card info-card skeleton-card">
      <view class="skeleton-row">
        <view class="skeleton-line sk-tag"></view>
        <view class="skeleton-line sk-short"></view>
      </view>
      <view class="skeleton-line sk-long skeleton-animate"></view>
      <view class="skeleton-line sk-medium skeleton-animate"></view>
      <view class="skeleton-divider"></view>
      <view class="skeleton-line sk-medium skeleton-animate"></view>
      <view class="skeleton-line sk-long skeleton-animate"></view>
    </view>
    <view class="card skeleton-card">
      <view class="skeleton-line sk-short skeleton-animate"></view>
      <view class="skeleton-line sk-long skeleton-animate"></view>
      <view class="skeleton-line sk-medium skeleton-animate"></view>
      <view class="skeleton-line sk-long skeleton-animate"></view>
      <view class="skeleton-line sk-medium skeleton-animate"></view>
    </view>
  </block>

  <!-- 错误/限制状态 -->
  <block wx:elif="{{errorCode}}">
    <view class="card error-card">
      <text class="error-title">{{errorMsg}}</text>
      <view wx:if="{{errorCode === 'PHONE_REQUIRED'}}" class="phone-area">
        <view class="phone-hint">请输入收件手机号后4位</view>
        <view class="phone-row">
          <input
            class="input phone-input"
            placeholder="手机号后4位"
            maxlength="4"
            type="number"
            value="{{phone}}"
            bindinput="onPhoneInput"
          />
          <button class="btn-primary phone-btn" bindtap="onPhoneSubmit">查询</button>
        </view>
      </view>
      <button wx:else class="btn-secondary retry-btn" bindtap="onRetry">返回重试</button>
    </view>
  </block>

  <!-- 正常结果 -->
  <block wx:else>
    <!-- 快递信息卡片 -->
    <view class="card info-card">
      <view class="info-status-row">
        <view class="tag {{stateTag}}">{{stateName}}</view>
        <text class="info-copy-action" bindtap="onCopyNum">复制单号</text>
      </view>
      <view class="info-status">{{latestTrace || stateName}}</view>
      <view class="info-status-time" wx:if="{{latestTime}}">最近更新 {{latestTime}}</view>
      <view class="info-meta-row">
        <text class="info-com">{{comName}}</text>
        <text class="info-num">运单号 {{nu}}</text>
      </view>
    </view>

    <!-- 物流轨迹时间轴 -->
    <view class="card timeline-card" wx:if="{{traces.length > 0}}">
      <view class="timeline-title">物流轨迹</view>
      <view class="timeline">
        <view
          class="timeline-item {{index === 0 ? 'latest' : ''}}"
          wx:for="{{traces}}"
          wx:key="time"
        >
          <view class="timeline-dot"></view>
          <view class="timeline-line" wx:if="{{index < traces.length - 1}}"></view>
          <view class="timeline-content">
            <view class="timeline-time">{{item.ftime || item.time}}</view>
            <view class="timeline-desc">{{item.context}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空轨迹 -->
    <view class="card empty-trace" wx:if="{{traces.length === 0}}">
      <text class="empty-trace-title">暂无物流更新</text>
      <text class="text-secondary">快递公司已记录该单号，物流信息通常会在后续运输节点同步。</text>
    </view>

  </block>

</scroll-view>

<!-- 隐藏 canvas 用于生成分享图，通过 root-portal 脱离 scroll-view -->
<root-portal>
  <canvas type="2d" id="shareCanvas" class="share-canvas"></canvas>
</root-portal>

<!-- 浮动分享按钮：root-portal 脱离文档流，确保 Skyline 下 fixed 生效 -->
<root-portal>
  <view class="fab-share" wx:if="{{!loading && !errorCode}}">
    <button class="fab-share-btn" open-type="share">
      <view class="fab-share-icon"></view>
    </button>
  </view>
</root-portal>
