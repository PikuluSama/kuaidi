/* pages/result/result.wxss */

.info-card {
  margin-top: 24rpx;
}

.info-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.info-copy-action {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.info-status {
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 600;
  color: var(--color-primary);
}

.info-status-time {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 12rpx;
}

.info-meta-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border);
}

.info-com {
  font-size: 26rpx;
  color: var(--color-primary);
}

.info-num {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 时间轴 */
.timeline-card {
  padding: 32rpx;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 24rpx;
}

.timeline {
  position: relative;
}

.timeline-item {
  position: relative;
  padding-left: 44rpx;
  padding-bottom: 36rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: 3rpx;
  top: 8rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background-color: var(--color-border-strong);
}

.timeline-line {
  position: absolute;
  left: 11rpx;
  top: 30rpx;
  bottom: 0;
  width: 2rpx;
  background-color: var(--color-border);
}

/* 最新一条高亮 */
.timeline-item.latest .timeline-dot {
  background-color: var(--color-brand);
  width: 22rpx;
  height: 22rpx;
  left: 1rpx;
  top: 6rpx;
}

.timeline-item.latest .timeline-line {
  left: 12rpx;
}

.timeline-item.latest .timeline-time {
  color: var(--color-brand);
}

.timeline-item.latest .timeline-desc {
  color: var(--color-primary);
}

.timeline-time {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 8rpx;
}

.timeline-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.65;
}

/* 空轨迹 */
.empty-trace {
  text-align: center;
  padding: 72rpx 32rpx;
}

.empty-trace-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

/* 分享 */
.share-area {
  padding: 24rpx 32rpx 60rpx;
}

.share-btn {
  width: 100% !important;
}
