/* pages/result/result.wxss */

.info-card {
  margin-top: 24rpx;
}

.info-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.info-copy-action {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.info-status {
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 600;
  color: var(--color-primary);
}

.info-status-time {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 12rpx;
}

.info-meta-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border);
}

.info-com {
  font-size: 26rpx;
  color: var(--color-primary);
}

.info-num {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 时间轴 */
.timeline-card {
  padding: 32rpx;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 24rpx;
}

.timeline {
  position: relative;
}

.timeline-item {
  position: relative;
  padding-left: 44rpx;
  padding-bottom: 36rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: 3rpx;
  top: 8rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background-color: var(--color-border-strong);
}

.timeline-line {
  position: absolute;
  left: 11rpx;
  top: 30rpx;
  bottom: 0;
  width: 2rpx;
  background-color: var(--color-border);
}

/* 最新一条高亮 */
.timeline-item.latest .timeline-dot {
  background-color: var(--color-brand);
  width: 22rpx;
  height: 22rpx;
  left: 1rpx;
  top: 6rpx;
}

.timeline-item.latest .timeline-line {
  left: 12rpx;
}

.timeline-item.latest .timeline-time {
  color: var(--color-brand);
}

.timeline-item.latest .timeline-desc {
  color: var(--color-primary);
}

.timeline-time {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 8rpx;
}

.timeline-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.65;
}

/* 空轨迹 */
.empty-trace {
  text-align: center;
  padding: 72rpx 32rpx;
}

.empty-trace-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.result-bottom-spacer {
  height: calc(env(safe-area-inset-bottom) + 164rpx);
}

.result-actions-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 20rpx 32rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: linear-gradient(180deg, rgba(245, 247, 245, 0), rgba(245, 247, 245, 0.96) 18%, #F5F7F5 100%);
}

.result-actions-shell {
  padding: 20rpx;
  background-color: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(227, 232, 227, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(17, 24, 21, 0.08);
  backdrop-filter: blur(16rpx);
}

.share-action-btn {
  width: 100% !important;
  box-shadow: 0 8rpx 24rpx rgba(31, 107, 69, 0.14);
}

/* 分享 canvas 隐藏 */
.share-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 600px;
  height: 480px;
}

/* 骨架屏 */
.skeleton-card {
  margin-top: 24rpx;
}

.skeleton-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.skeleton-line {
  position: relative;
  height: 28rpx;
  border-radius: 8rpx;
  background-color: var(--color-bg-soft);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.skeleton-line:last-child {
  margin-bottom: 0;
}

.sk-tag {
  width: 120rpx;
  height: 40rpx;
  border-radius: 999rpx;
}

.sk-short {
  width: 120rpx;
}

.sk-medium {
  width: 60%;
}

.sk-long {
  width: 85%;
}

.skeleton-animate {
  background-color: var(--color-bg-soft);
}

.skeleton-animate::after {
  content: '';
  position: absolute;
  top: 0;
  left: -40%;
  width: 40%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0));
  transform: skewX(-18deg);
  animation: shimmer 1.6s ease-in-out infinite;
}

.skeleton-divider {
  height: 1rpx;
  background-color: var(--color-border);
  margin: 24rpx 0;
}

@keyframes shimmer {
  0% { transform: translateX(0) skewX(-18deg); }
  100% { transform: translateX(350%) skewX(-18deg); }
}

/* 错误状态 */
.error-card {
  margin-top: 24rpx;
  text-align: center;
  padding: 60rpx 32rpx;
}

.error-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.retry-btn {
  width: 60% !important;
  margin: 0 auto;
}

/* 手机号输入 */
.phone-area {
  text-align: left;
  margin-bottom: 32rpx;
}

.phone-hint {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.phone-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.phone-row .phone-input {
  flex: 1;
  margin-top: 0;
}

.phone-btn {
  flex-shrink: 0;
  width: 160rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: 28rpx;
}
